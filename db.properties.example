# ─────────────────────────────────────────────────────────────────────────────
# db.properties.example
#
# HOW TO USE:
#   cp db.properties.example db.properties
#
# db.properties is gitignored so it never gets committed.
# This file is the committed reference.
# Use placeholders only — never commit real passwords here.
#
# The key prefix must match your OS username exactly.
# Find yours by running:  whoami
# ─────────────────────────────────────────────────────────────────────────────

